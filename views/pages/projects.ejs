<%- include('../partials/header') %>

<h1><%=title%></h1>
<p>A gallery of what I've been working on.</p>

<div class="card mb-4">
  <div class="row no-gutters">
    <div class="col-md-4">
      <img src="/images/stylin_with_css_project_image.png" class="card-img" alt="Styling with CSS project screenshot">
    </div>
    <div class="col-md-8">
      <div class="card-body">
        <h4 class="card-title">Styling with CSS</h4>
        <p class="card-text">An exploration of CSS fundamentals: selectors, the box model, styled tables, and keyframe animations. Built to practice turning plain HTML into a clean, readable layout from the ground up.</p>
        <a href="https://vale310.github.io/stylin-with-css/" class="btn btn-primary" target="_blank">Live Demo</a>
        <a href="https://github.com/Vale310/stylin-with-css" class="btn btn-secondary" target="_blank">GitHub Repo</a>
      </div>
    </div>
  </div>
</div>

<div class="card mb-4">
  <div class="row no-gutters">
    <div class="col-md-4">
      <img src="/images/css_pos_and_layout_project_image.png" class="card-img" alt="CSS Positioning project screenshot">
    </div>
    <div class="col-md-8">
      <div class="card-body">
        <h4 class="card-title">CSS Positioning &amp; Layout</h4>
        <p class="card-text">A hands-on study of page layout and positioning: centering techniques, floats, flexbox, and responsive media queries that adapt the design across phone, tablet, and desktop.</p>
        <a href="https://vale310.github.io/css-positioning/" class="btn btn-primary" target="_blank">Live Demo</a>
        <a href="https://github.com/Vale310/css-positioning" class="btn btn-secondary" target="_blank">GitHub Repo</a>
      </div>
    </div>
  </div>
</div>

<div class="card mb-4">
  <div class="row no-gutters">
    <div class="col-md-4">
      <img src="/images/dom_play_project_image.jpg" class="card-img" alt="DOM Play project screenshot">
    </div>
    <div class="col-md-8">
      <div class="card-body">
        <h4 class="card-title">DOM Play</h4>
        <p class="card-text">An interactive page driven by JavaScript and the DOM, responding to user actions right in the browser. Focused on connecting HTML elements to behavior and handling events cleanly.</p>
        <a href="https://vale310.github.io/dom-play/" class="btn btn-primary" target="_blank">Live Demo</a>
        <a href="https://github.com/Vale310/dom-play" class="btn btn-secondary" target="_blank">GitHub Repo</a>
